# EditorConfig - consistent formatting across editors
# https://editorconfig.org

root = true

[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8
trim_trailing_whitespace = true

[*.asm]
indent_style = space
indent_size = 8

[*.inc]
indent_style = space
indent_size = 8

[Makefile]
indent_style = tab
indent_size = 8

[*.py]
indent_style = space
indent_size = 4

[*.md]
trim_trailing_whitespace = false

[*.sh]
indent_style = space
indent_size = 4
